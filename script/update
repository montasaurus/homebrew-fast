#!/usr/bin/env ruby
# frozen_string_literal: true

require "json"
require "net/http"
require "openssl"
require "uri"

ROOT = File.expand_path("..", __dir__)

PACKAGES = {
  "codex" => {
    type: :cask,
    file: "Casks/codex.rb",
    sha_order: %i[arm intel arm64_linux x86_64_linux],
    labels: {
      arm: "arm",
      intel: "intel",
      arm64_linux: "arm64_linux",
      x86_64_linux: "x86_64_linux",
    },
    github_repo: "openai/codex",
    tag_regex: /\Arust-v(\d+(?:\.\d+)+)\z/,
    assets: {
      arm: "codex-aarch64-apple-darwin.tar.gz",
      intel: "codex-x86_64-apple-darwin.tar.gz",
      arm64_linux: "codex-aarch64-unknown-linux-musl.tar.gz",
      x86_64_linux: "codex-x86_64-unknown-linux-musl.tar.gz",
    },
    url_for: lambda { |version, key|
      asset = PACKAGES.fetch("codex").fetch(:assets).fetch(key)
      "https://github.com/openai/codex/releases/download/rust-v#{version}/#{asset}"
    },
  },
  "claude-code" => {
    type: :cask,
    file: "Casks/claude-code.rb",
    sha_order: %i[arm x86_64 x86_64_linux arm64_linux],
    labels: {
      arm: "arm",
      x86_64: "x86_64",
      x86_64_linux: "x86_64_linux",
      arm64_linux: "arm64_linux",
    },
    latest_url: "https://storage.googleapis.com/claude-code-dist-86c565f3-f756-42ad-8dfa-d59b1c096819/claude-code-releases/latest",
    manifest_url: lambda { |version|
      "https://storage.googleapis.com/claude-code-dist-86c565f3-f756-42ad-8dfa-d59b1c096819/claude-code-releases/#{version}/manifest.json"
    },
    version_regex: /\Av?(\d+(?:\.\d+)+)\z/,
    paths: {
      arm: "darwin-arm64",
      x86_64: "darwin-x64",
      x86_64_linux: "linux-x64",
      arm64_linux: "linux-arm64",
    },
    url_for: lambda { |version, key|
      path = PACKAGES.fetch("claude-code").fetch(:paths).fetch(key)
      "https://storage.googleapis.com/claude-code-dist-86c565f3-f756-42ad-8dfa-d59b1c096819/claude-code-releases/#{version}/#{path}/claude"
    },
  },
}.freeze

def usage
  warn "usage: script/update <#{PACKAGES.keys.join('|')}|all> [--dry-run]"
  exit 1
end

def http_request(url, headers: {}, limit: 5, &block)
  raise "too many redirects fetching #{url}" if limit < 0

  uri = URI(url)
  request = Net::HTTP::Get.new(uri)
  request["User-Agent"] = "homebrew-fast-updater"
  headers.each { |key, value| request[key] = value }

  Net::HTTP.start(uri.host, uri.port, use_ssl: uri.scheme == "https") do |http|
    http.request(request) do |response|
      case response
      when Net::HTTPSuccess
        return block ? block.call(response) : response.body
      when Net::HTTPRedirection
        location = response["location"] or raise "redirect without location for #{url}"
        return http_request(location, headers: headers, limit: limit - 1, &block)
      else
        raise "request failed for #{url}: #{response.code} #{response.message}"
      end
    end
  end
end

def github_headers
  headers = {
    "Accept" => "application/vnd.github+json",
    "X-GitHub-Api-Version" => "2022-11-28",
  }

  token = ENV["GITHUB_TOKEN"] || ENV["GH_TOKEN"]
  headers["Authorization"] = "Bearer #{token}" if token && !token.empty?
  headers
end

def latest_github_release(package_name)
  config = PACKAGES.fetch(package_name)
  page = 1
  release = nil

  loop do
    releases = JSON.parse(http_request("https://api.github.com/repos/#{config.fetch(:github_repo)}/releases?per_page=100&page=#{page}", headers: github_headers))
    break if releases.empty?

    release = releases.find do |item|
      !item.fetch("draft") &&
        !item.fetch("prerelease") &&
        item.fetch("tag_name").match?(config.fetch(:tag_regex))
    end

    break if release

    page += 1
  end

  raise "no stable #{package_name} release found" unless release

  version = release.fetch("tag_name")[config.fetch(:tag_regex), 1]
  [version, release]
end

def latest_claude_version
  body = http_request(PACKAGES.fetch("claude-code").fetch(:latest_url)).strip
  match = PACKAGES.fetch("claude-code").fetch(:version_regex).match(body)
  raise "unexpected claude-code latest marker: #{body.inspect}" unless match

  match[1]
end

def claude_manifest(version)
  manifest_url = PACKAGES.fetch("claude-code").fetch(:manifest_url).call(version)
  manifest = JSON.parse(http_request(manifest_url))
  manifest_version = manifest["version"]

  return manifest if manifest_version == version

  raise "unexpected claude-code manifest version #{manifest_version.inspect} for #{version}"
end

def remote_sha256(url)
  digest = OpenSSL::Digest::SHA256.new
  http_request(url) do |response|
    response.read_body do |chunk|
      digest.update(chunk)
    end
  end
  digest.hexdigest
end

def github_asset_shas(package_name, release, version)
  config = PACKAGES.fetch(package_name)
  assets = release.fetch("assets").each_with_object({}) do |asset, memo|
    memo[asset.fetch("name")] = asset
  end

  config.fetch(:sha_order).to_h do |key|
    asset_name = config.fetch(:assets).fetch(key)
    asset = assets.fetch(asset_name) { raise "missing #{package_name} asset #{asset_name} for #{version}" }
    digest = asset["digest"]
    sha = if digest&.start_with?("sha256:")
      digest.delete_prefix("sha256:")
    else
      remote_sha256(asset.fetch("browser_download_url"))
    end
    [key, sha]
  end
end

def claude_shas(manifest, version)
  platforms = manifest.fetch("platforms")
  PACKAGES.fetch("claude-code").fetch(:sha_order).to_h do |key|
    path = PACKAGES.fetch("claude-code").fetch(:paths).fetch(key)
    checksum = platforms.dig(path, "checksum")
    raise "missing claude-code checksum for #{version} #{path}" unless checksum

    [key, checksum]
  end
end

def current_version(content)
  content[/^  version "([^"]+)"$/, 1]
end

def render_cask_sha_block(package_name, shas)
  labels = PACKAGES.fetch(package_name).fetch(:labels)
  order = PACKAGES.fetch(package_name).fetch(:sha_order)
  width = order.map { |key| labels.fetch(key).length }.max

  order.each_with_index.map do |key, index|
    label = labels.fetch(key)
    prefix = index.zero? ? "  sha256 " : "         "
    suffix = index == order.length - 1 ? "" : ","
    %(#{prefix}#{label}:#{" " * (width - label.length + 1)}"#{shas.fetch(key)}"#{suffix})
  end.join("\n")
end

def update_formula_shas(content, package_name, shas)
  order = PACKAGES.fetch(package_name).fetch(:sha_order)
  index = 0
  updated = content.gsub(/^      sha256 "[0-9a-f]{64}"$/) do
    key = order.fetch(index) do
      raise "too many sha256 lines in #{package_name}"
    end
    index += 1
    %(      sha256 "#{shas.fetch(key)}")
  end

  raise "expected #{order.length} sha256 lines in #{package_name}, found #{index}" unless index == order.length

  updated
end

def update_file(package_name, version, shas, dry_run:)
  config = PACKAGES.fetch(package_name)
  path = File.join(ROOT, config.fetch(:file))
  original = File.read(path)

  updated = original.sub(/^  version "([^"]+)"$/, %(  version "#{version}"))
  updated = case config.fetch(:type)
  when :cask
    updated.sub(/^  sha256 .*?(?=^  url )/m, "#{render_cask_sha_block(package_name, shas)}\n\n")
  when :formula
    update_formula_shas(updated, package_name, shas)
  else
    raise "unknown package type #{config.fetch(:type)} for #{package_name}"
  end

  changed = updated != original
  File.write(path, updated) if changed && !dry_run

  [path, changed, current_version(original)]
end

def resolve_latest(package_name)
  case package_name
  when "codex"
    version, release = latest_github_release(package_name)
    [version, release]
  when "claude-code"
    version = latest_claude_version
    [version, claude_manifest(version)]
  else
    raise "unknown package #{package_name}"
  end
end

def package_shas(package_name, metadata, version)
  case package_name
  when "codex"
    github_asset_shas(package_name, metadata, version)
  when "claude-code"
    claude_shas(metadata, version)
  else
    raise "unknown package #{package_name}"
  end
end

def update_package(package_name, dry_run:)
  config = PACKAGES.fetch(package_name)
  path = File.join(ROOT, config.fetch(:file))
  original = File.read(path)
  existing_version = current_version(original)
  latest_version, metadata = resolve_latest(package_name)

  if latest_version == existing_version
    puts "#{package_name} already current at #{existing_version}"
    return
  end

  shas = package_shas(package_name, metadata, latest_version)

  path, changed, previous_version = update_file(package_name, latest_version, shas, dry_run: dry_run)

  if changed
    action = dry_run ? "would update" : "updated"
    puts "#{action} #{package_name}: #{previous_version} -> #{latest_version} (#{path})"
  else
    puts "#{package_name} already current at #{existing_version}"
  end
end

args = ARGV.dup
dry_run = args.delete("--dry-run")
target = args.shift
usage unless target && args.empty?

targets = target == "all" ? PACKAGES.keys : [target]
targets.each do |package_name|
  update_package(package_name, dry_run: dry_run)
end
